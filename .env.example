DATABASE_URL="postgresql://user:password@localhost:5432/complysafe"
NEXT_PUBLIC_APP_NAME="ComplySafe"

# Encryption (required in development, must be set in production)
# Generate a secure random hex key: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=""

# Fallback secret for development only (required in non-production)
ENCRYPTION_FALLBACK_SECRET="your-dev-secret-change-in-production"
